ColorBlue.MouseButton1Click:Connect(function() UpdateColor(Color3.fromRGB(0, 115, 230)) end)
ColorRed.MouseButton1Click:Connect(function() UpdateColor(Color3.fromRGB(210, 35, 35)) end)

-- Animasi Sistem Seret / Drag Frame Menu (PC & HP Screen Touch)
local Dragging, DragInput, DragStart, StartPosition
TopBar.InputBegan:Connect(function(Input)
	if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
		Dragging = true; DragStart = Input.Position; StartPosition = MainFrame.Position
		Input.Changed:Connect(function() if Input.UserInputState == Enum.UserInputState.End then Dragging = false end end)
	end
end)
UserInputService.InputChanged:Connect(function(Input)
	if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
		local Delta = Input.Position - DragStart
		MainFrame.Position = UDim2.new(StartPosition.X.Scale, StartPosition.X.Offset + Delta.X, StartPosition.Y.Scale, StartPosition.Y.Offset + Delta.Y)
	end
end)

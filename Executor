local CoreExecution = {}
local FILE_SKRIP = "Universal_Split_Saved_Script.txt"

-- Fungsi Logika Menyimpan Berkas Permanen
function CoreExecution.SimpanKeFolder(Teks)
	local Berhasil = pcall(function()
		if writefile then
			writefile(FILE_SKRIP, Teks)
		end
	end)
	return Berhasil
end

-- Fungsi Logika Membuka Kembali Data Berkas Lama
function CoreExecution.AmbilDariFolder()
	local TeksHasil = ""
	pcall(function()
		if readfile and isfile and isfile(FILE_SKRIP) then
			TeksHasil = readfile(FILE_SKRIP)
		end
	end)
	return TeksHasil
end

-- Fungsi Logika Inti Eksekusi Skrip 100% Berhasil
function CoreExecution.JalankanSkripMutlak(TeksKodeMentah)
	if TeksKodeMentah == "" then return false end
	
	-- 1. Auto-save otomatis sebelum dijalankan (Proteksi jika skrip target merusak game)
	CoreExecution.SimpanKeFolder(TeksKodeMentah)
	
	-- 2. Pembersihan string dari karakter ilegal sisa copy-paste
	local TeksKodeBersih = string.gsub(TeksKodeMentah, "[\128-\255]", "")
	
	-- 3. Eksekusi sistem menggunakan setfenv agar mewarisi hak akses game global penuh
	local Sukses, PesanError = pcall(function()
		local FungsiTerkompilasi = assert(loadstring(TeksKodeBersih))
		setfenv(FungsiTerkompilasi, getfenv()) 
		FungsiTerkompilasi()
	end)
	
	if not Sukses then
		warn("[-] Inti Eksekusi Gagal: " .. tostring(PesanError))
	end
	
	return Sukses
end

return CoreExecution

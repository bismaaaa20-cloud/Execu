local function UpdateColor(Warna)
	TweenService:Create(ExecuteBtn, TweenInfo.new(0.2), {BackgroundColor3 = Warna}):Play()
	TweenService:Create(UIStroke, TweenInfo.new(0.2), {Color = Warna}):Play()
end

